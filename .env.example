# Copy to .env and fill in values.

# Required for NextAuth (JWT). Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# PostgreSQL (Neon, Supabase, Vercel Postgres, etc.)
# Vercel: Settings → Environment Variables → Production (+ Preview). Save → Redeploy.
# 빌드 시 migrate deploy에 필요합니다. Vercel Postgres는 POSTGRES_PRISMA_URL 만 있어도 됩니다(코드에서 DATABASE_URL로 맞춤).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
