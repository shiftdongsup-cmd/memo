# Copy to .env and fill in values.

# Required for NextAuth (JWT). Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# PostgreSQL connection string (Neon, Supabase, Vercel Postgres, local Docker, etc.)
# On Vercel: Project → Settings → Environment Variables (Production + Preview).
# DATABASE_URL must exist during *build* (migrate deploy). Same for AUTH_SECRET at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
